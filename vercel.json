{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/track/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/import-leads",
      "destination": "backend/server.js"
    },
    {
      "source": "/health",
      "destination": "backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
