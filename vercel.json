{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/track/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/import-leads",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1",
      "continue": true
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ]
}
