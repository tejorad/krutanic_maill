# =============================================
#  ENVIRONMENT CONFIGURATION — email-system
# =============================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/email_system

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- BullMQ Queue ---
QUEUE_NAME=email-queue
WORKER_CONCURRENCY=50

# --- SMTP ---
SMTP_MAX_RETRIES=3

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./logs

# --- Auth & Tracking ---
JWT_SECRET=your_jwt_secret_here
TRACKING_BASE_URL=https://your-app.vercel.app # Base URL for open/click tracking

# --- SMTP Encryption ---
ENCRYPTION_KEY= # Generate a 32-character hex key (node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
